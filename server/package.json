{
  "name": "battlezone-server",
  "version": "1.0.0",
  "description": "BattleZone game server",
  "main": "src/index.js",
  "scripts": {
    "start":   "node src/index.js",
    "dev":     "nodemon src/index.js",
    "test":    "jest --coverage",
    "test:unit": "jest tests/unit --coverage",
    "test:int":  "jest tests/integration --coverage",
    "lint":    "eslint src --ext .js"
  },
  "engines": { "node": ">=20.0.0" },
  "dependencies": {
    "bcryptjs":         "^2.4.3",
    "compression":      "^1.7.4",
    "cors":             "^2.8.5",
    "express":          "^4.19.2",
    "express-rate-limit": "^7.3.1",
    "helmet":           "^7.1.0",
    "jsonwebtoken":     "^9.0.2",
    "pg":               "^8.11.5",
    "rate-limit-redis": "^4.2.0",
    "redis":            "^4.6.15",
    "socket.io":        "^4.7.5",
    "stripe":           "^15.12.0",
    "uuid":             "^10.0.0",
    "validator":        "^13.12.0"
  },
  "devDependencies": {
    "jest":             "^29.7.0",
    "nodemon":          "^3.1.4",
    "eslint":           "^9.5.0",
    "supertest":        "^7.0.0"
  },
  "jest": {
    "testEnvironment": "node",
    "setupFiles":      ["./tests/setup.js"],
    "collectCoverageFrom": [
      "src/**/*.js",
      "!src/index.js"
    ],
    "coverageThreshold": {
      "global": { "branches": 90, "functions": 90, "lines": 90, "statements": 90 }
    },
    "testPathPattern": "tests/"
  }
}
