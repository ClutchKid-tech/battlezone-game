# ─────────────────────────────────────────────────────────────────────────────
#  BattleZone — Environment Variables Reference
#  Copy to .env and fill in all values before starting the server.
#  NEVER commit .env to version control.
# ─────────────────────────────────────────────────────────────────────────────

# ── Server ────────────────────────────────────────────────────────────────────

# Port the game server listens on
PORT=8080

# Node environment: development | production | test
NODE_ENV=development

# Origin of the web client (for CORS)
CLIENT_ORIGIN=http://localhost:3000

# Maximum concurrent game rooms per server process (scale horizontally for more)
MAX_ROOMS=20

# Minimum players to start a match (set low for dev, 10+ for production)
MIN_START_PLAYERS=2

# Game server tick rate in Hz (target 64)
TICK_RATE=64

# ── Authentication ────────────────────────────────────────────────────────────

# MUST be a cryptographically random string of at least 64 characters
JWT_SECRET=REPLACE_WITH_SECURE_RANDOM_64_CHAR_STRING

# JWT issuer / audience (used for token validation)
JWT_ISSUER=battlezone
JWT_AUDIENCE=battlezone-client

# ── TLS (production only) ────────────────────────────────────────────────────

# Paths to TLS certificate and key files (leave empty in dev)
TLS_CERT=
TLS_KEY=

# ── PostgreSQL ────────────────────────────────────────────────────────────────

# Full connection string (used by node-postgres Pool)
DATABASE_URL=postgresql://battlezone:password@localhost:5432/battlezone

# Maximum connections in the pool per process
PG_POOL_MAX=20

# ── Redis ─────────────────────────────────────────────────────────────────────

REDIS_URL=redis://localhost:6379

# ── Stripe ────────────────────────────────────────────────────────────────────

# Secret key (server-side only — never expose to client)
STRIPE_SECRET_KEY=sk_test_REPLACE_WITH_YOUR_STRIPE_SECRET_KEY

# Webhook signing secret (from Stripe Dashboard → Webhooks)
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_WITH_WEBHOOK_SECRET

# ── Client-side Vite variables (prefix VITE_) ────────────────────────────────
# These are embedded at build time — do NOT put secrets here

# URL of the game server (used by Socket.io and fetch)
VITE_SERVER_URL=http://localhost:8080

# Stripe publishable key (safe to expose)
VITE_STRIPE_PUBLIC_KEY=pk_test_REPLACE_WITH_YOUR_STRIPE_PUBLISHABLE_KEY

# ── AWS / GCS (for match replay storage) ─────────────────────────────────────

AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=REPLACE
AWS_SECRET_ACCESS_KEY=REPLACE
REPLAY_BUCKET_NAME=battlezone-replays

# ── Monitoring ────────────────────────────────────────────────────────────────

# Sentry DSN for error tracking (optional)
SENTRY_DSN=

# Datadog API key (optional)
DD_API_KEY=
